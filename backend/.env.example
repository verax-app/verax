# Copy this to .env.local / .env.staging / .env.production and fill in values.
# APP_ENV is set at process start (make run-backend), not read from this file.

DATABASE_URL=sqlite:///./verax.db
AI_PROVIDER=ollama
OLLAMA_MODEL=llama3.2
OLLAMA_HOST=http://localhost:11434
GROQ_API_KEY=
GEMINI_API_KEY=
FETCH_INTERVAL_MINUTES=30
SUMMARIZE_INTERVAL_MINUTES=2
ARTICLES_PER_FEED=10
BATCH_SUMMARIZE=10
